{
  "openapi": "3.0.3",
  "info": {
    "title": "WeChat Assistant API",
    "version": "3.0.0",
    "description": "微信公众号视频上传服务。主流程为：公众号回复 6 位上传码，H5 页面填写上传码后分片上传到腾讯云 COS，业务数据写入 PostgreSQL。"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "本地开发"
    }
  ],
  "tags": [
    {
      "name": "meta",
      "description": "健康检查与契约"
    },
    {
      "name": "wechat",
      "description": "微信公众号回调"
    },
    {
      "name": "video_collector",
      "description": "参与者、H5 上传、审核"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "与 API_SECRET 相同"
      },
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "与 API_SECRET 相同"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "hint": {
            "type": "string"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "checks": {
            "type": "object"
          }
        }
      },
      "Participant": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "wechat_openid": {
            "type": "string"
          },
          "real_name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "participant_code": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "paused",
              "withdrawn"
            ]
          },
          "extra": {
            "type": "object",
            "additionalProperties": true
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        }
      },
      "ParticipantWrap": {
        "type": "object",
        "required": [
          "participant"
        ],
        "properties": {
          "participant": {
            "$ref": "#/components/schemas/Participant"
          }
        }
      },
      "CreateParticipantBody": {
        "type": "object",
        "required": [
          "wechat_openid",
          "real_name",
          "phone"
        ],
        "properties": {
          "wechat_openid": {
            "type": "string"
          },
          "real_name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "extra": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "VideoSubmission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "participant_id": {
            "type": "integer",
            "format": "int64"
          },
          "participant_code": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "chat",
              "h5"
            ]
          },
          "wechat_media_id": {
            "type": "string",
            "nullable": true
          },
          "object_key": {
            "type": "string"
          },
          "file_name": {
            "type": "string",
            "nullable": true
          },
          "size_bytes": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "mime": {
            "type": "string",
            "nullable": true
          },
          "duration_sec": {
            "type": "number",
            "nullable": true
          },
          "user_comment": {
            "type": "string",
            "nullable": true
          },
          "review_status": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "rejected"
            ]
          },
          "reject_reason": {
            "type": "string",
            "nullable": true
          },
          "reviewed_at": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string"
          },
          "object_url": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "SubmissionsListResponse": {
        "type": "object",
        "required": [
          "submissions"
        ],
        "properties": {
          "submissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VideoSubmission"
            }
          }
        }
      },
      "SubmissionSingleResponse": {
        "type": "object",
        "required": [
          "submission"
        ],
        "properties": {
          "submission": {
            "$ref": "#/components/schemas/VideoSubmission"
          }
        }
      },
      "PatchSubmissionBody": {
        "type": "object",
        "properties": {
          "review_status": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "rejected"
            ]
          },
          "reject_reason": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "H5LookupResponse": {
        "type": "object",
        "required": [
          "participant",
          "submissions"
        ],
        "properties": {
          "participant": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64"
              },
              "participant_code": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "display_name": {
                "type": "string"
              },
              "display_phone": {
                "type": "string"
              }
            }
          },
          "submissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VideoSubmission"
            }
          }
        }
      },
      "MultipartInitBody": {
        "type": "object",
        "required": [
          "participant_code",
          "size_bytes"
        ],
        "properties": {
          "participant_code": {
            "type": "string"
          },
          "content_type": {
            "type": "string",
            "default": "video/mp4"
          },
          "file_name": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "format": "int64"
          },
          "user_comment": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "健康检查",
        "security": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "OpenAPI 契约",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/wechat": {
      "get": {
        "tags": [
          "wechat"
        ],
        "summary": "微信公众号服务器校验",
        "security": [],
        "responses": {
          "200": {
            "description": "返回 echostr"
          }
        }
      },
      "post": {
        "tags": [
          "wechat"
        ],
        "summary": "微信公众号消息回调",
        "security": [],
        "responses": {
          "200": {
            "description": "success 或被动回复 XML"
          }
        }
      }
    },
    "/api/h5/code/{participantCode}": {
      "get": {
        "tags": [
          "video_collector"
        ],
        "summary": "H5 按上传码查询用户和记录",
        "security": [],
        "parameters": [
          {
            "name": "participantCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/H5LookupResponse"
                }
              }
            }
          },
          "404": {
            "description": "上传码不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/participants": {
      "post": {
        "tags": [
          "video_collector"
        ],
        "summary": "登记用户并分配上传码",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateParticipantBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/participants/by_openid": {
      "get": {
        "tags": [
          "video_collector"
        ],
        "summary": "按 openid 查询参与者",
        "parameters": [
          {
            "name": "wechat_openid",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParticipantWrap"
                }
              }
            }
          }
        }
      }
    },
    "/participants/code/{participant_code}": {
      "get": {
        "tags": [
          "video_collector"
        ],
        "summary": "按上传码查询参与者",
        "parameters": [
          {
            "name": "participant_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParticipantWrap"
                }
              }
            }
          }
        }
      }
    },
    "/upload/multipart/init": {
      "post": {
        "tags": [
          "video_collector"
        ],
        "summary": "创建分片上传会话",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MultipartInitBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/upload/multipart/part": {
      "post": {
        "tags": [
          "video_collector"
        ],
        "summary": "获取单个分片上传签名",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "patch": {
        "tags": [
          "video_collector"
        ],
        "summary": "登记单个分片 ETag",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/upload/multipart/complete": {
      "post": {
        "tags": [
          "video_collector"
        ],
        "summary": "完成分片上传并写入投稿记录",
        "security": [],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/upload/multipart/session/{sessionId}": {
      "get": {
        "tags": [
          "video_collector"
        ],
        "summary": "查询分片上传会话",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "video_collector"
        ],
        "summary": "放弃分片上传会话",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/admin/submissions": {
      "get": {
        "tags": [
          "video_collector"
        ],
        "summary": "审核列表",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionsListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/submissions/{submission_id}": {
      "get": {
        "tags": [
          "video_collector"
        ],
        "summary": "单条投稿详情",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionSingleResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "video_collector"
        ],
        "summary": "更新审核状态",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatchSubmissionBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    },
    {
      "ApiKeyAuth": []
    }
  ]
}
