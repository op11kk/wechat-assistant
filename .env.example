SUPABASE_URL=https://your-project.supabase.co
# 服务端需要可以 insert / update，请填写 Supabase 项目的 service_role secret，不要填 publishable key。
SUPABASE_KEY=your_supabase_service_role_secret

# 留空则除 GET /health、GET|POST /api/wechat、GET /h5 外不做接口鉴权；生产环境建议配置随机长串。
API_SECRET=

# 微信服务号配置
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Optional: fixed outbound IP media worker. When configured, /api/wechat will dispatch
# WeChat media download + COS upload to this worker instead of doing it on Vercel.
WECHAT_MEDIA_WORKER_URL=https://your-fixed-ip-worker.example.com/wechat-media-sync
WECHAT_MEDIA_WORKER_SECRET=change-me
WECHAT_MEDIA_WORKER_TIMEOUT_MS=10000

# Optional: if the machine receiving WeChat callbacks cannot access Supabase directly,
# point it to a Vercel/private API route that only performs participant lookup + row insert.
WECHAT_INGEST_API_URL=
WECHAT_INGEST_API_SECRET=
WECHAT_INGEST_API_TIMEOUT_MS=10000

# Cloudflare R2 配置。四项都填齐后 /upload/presign 才会返回可用预签名。
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=

# 可选：如果你给 R2 配了自定义公开域名，可在接口里直接返回 object_url。
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# Tencent COS alternative. Fill these instead of the R2 variables if you want to use COS.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
# 控制台「存储桶名称」，一般为 名称-APPID，勿含多余「.」；与 region 对应。
COS_BUCKET=
# Optional public base URL, for example https://your-bucket.cos.ap-guangzhou.myqcloud.com
COS_PUBLIC_BASE_URL=

# Worker runtime secret. Use this on the fixed-IP server; Vercel uses WECHAT_MEDIA_WORKER_SECRET.
WORKER_SECRET=change-me
