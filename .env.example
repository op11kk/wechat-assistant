SUPABASE_URL=https://你的项目.supabase.co
# 本仓库服务端须能 insert：请填 service_role（Dashboard → API → Secret keys 里带 secret 的那把）。
# 不要用 sb_publishable_（publishable）。若 /health 的 supabase_ref 总不对，检查系统环境变量是否残留旧 SUPABASE_URL，或已用 override 加载本目录 .env。
SUPABASE_KEY=你的_service_role_secret_勿填_publishable

# 留空则除 GET /health、/wechat/callback 外不校验；生产务必设置随机长串
API_SECRET=

# 排障：设为 1 并重启后，GET /health 会多返回 diag（app 路径、实际加载的 .env 路径等），用完删掉
# IOSBEHIND_DIAG=1

# debug 下默认会起两个 Python（reloader）；若 netstat 里两个 LISTENING 困扰你，可改为单进程（改代码后不自动重载）
# FLASK_USE_RELOADER=0
# 仍有两个 LISTENING 时：先结束所有 python.exe 再只启动一次；或设 FLASK_DEBUG=0（无调试器，单进程最稳）
# FLASK_DEBUG=0

# 监听端口，默认 5000。若本机 iosopen 的 H5 占 5000，可设 FLASK_PORT=5001，前端 API_BASE 指向同一端口。
# FLASK_PORT=5001

# 微信（测试号在 sandbox 页；正式号在 开发→基本配置 / 消息推送）
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 腾讯云 COS（四行都填齐后 /upload/presign 才不是 503；桶名见控制台「存储桶名称」全串）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
