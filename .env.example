DATABASE_URL=postgresql://wechat_user:change-me@127.0.0.1:5432/wechat_assistant

# Leave empty to disable auth on internal admin APIs. Production should set a long random secret.
API_SECRET=

# Public H5 deployment split. Leave NEXT_PUBLIC_API_BASE_URL empty for same-origin/local dev.
# Set NEXT_PUBLIC_API_BASE_URL=https://api.capego.top when the H5 page is hosted on Vercel.
NEXT_PUBLIC_API_BASE_URL=
H5_CORS_ALLOWED_ORIGINS=https://app.capego.top,http://127.0.0.1:3002,http://localhost:3002

# WeChat Official Account server config
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Optional fallback worker. The main Tencent Cloud deployment no longer needs this in the primary path,
# but the worker can still be kept as a manual/backfill tool if desired.
WECHAT_MEDIA_WORKER_URL=
WECHAT_MEDIA_WORKER_SECRET=
WECHAT_MEDIA_WORKER_TIMEOUT_MS=10000

# Legacy remote ingest bridge. Keep empty in the Tencent Cloud PostgreSQL deployment.
WECHAT_INGEST_API_URL=
WECHAT_INGEST_API_SECRET=
WECHAT_INGEST_API_TIMEOUT_MS=10000

# Cloudflare R2 config. Fill these four together if you want to use R2 instead of COS.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# Tencent COS config. Fill these instead of the R2 variables for the mainland deployment.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_PUBLIC_BASE_URL=

# Worker runtime secret. Only needed if you still run workers/wechat-media-worker.mjs.
WORKER_SECRET=change-me
